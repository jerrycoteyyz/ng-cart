# Copy this file to .env.production on the EC2 instance and fill in real values.
# Run with: docker compose --env-file .env.production -f docker-compose.prod.yml up -d

# ── RDS PostgreSQL ──────────────────────────────────────────────────────────
DB_HOST=your-cluster.xxxxxxxxxxxx.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=ngcart
DB_USER=ngcart
DB_PASSWORD=replace-with-strong-password

# ── Auth ────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-long-random-string

# ── CORS ────────────────────────────────────────────────────────────────────
# Your public domain or EC2 public IP (include scheme, no trailing slash)
ALLOWED_ORIGIN=https://your-domain.com

# ── Analytics project path ──────────────────────────────────────────────────
# Path to the orders_and_payments repo on this server, relative to ng-cart
ANALYTICS_PATH=../orders_and_payments
